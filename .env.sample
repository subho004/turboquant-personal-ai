PORT=8000
ENV=development
DEBUG=True

# OpenAI
OPENAI_API_KEY=sk-...
EMBED_MODEL=text-embedding-3-small
# gpt-5.5-mini is not a released model id yet; gpt-5-mini is the closest small model.
CHAT_MODEL=gpt-5-mini
TRANSCRIBE_MODEL=whisper-1

# Storage (SQLite + on-disk TurboVec indexes live under DATA_DIR)
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
DATA_DIR=./data
